{
  "permissions": {
    "allow": [
      "mcp__playwright__*"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/format-on-edit.mjs",
            "timeout": 10000,
            "async": true,
            "statusMessage": "format-on-edit"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/typecheck-on-stop.mjs",
            "timeout": 60000,
            "async": false,
            "statusMessage": "vue-tsc"
          }
        ]
      }
    ]
  }
}
